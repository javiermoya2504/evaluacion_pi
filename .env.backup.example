# PostgreSQL backup + Google Drive upload
#
# Copy this file outside Git, for example to /etc/evaluacion-pi/backup.env,
# and fill in the real values on the server that runs cron.

# Preferred option. This is the same format accepted by pg_dump and pg_restore.
DATABASE_URL=postgresql://usuario:password@localhost:5432/evaluacion_pi

# Alternative if DATABASE_URL is not used:
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=evaluacion_pi
# PGUSER=postgres
# PGPASSWORD=postgres

# rclone remote previously configured with Google Drive.
# Example setup command on the server: rclone config
RCLONE_REMOTE=gdrive
RCLONE_BACKUP_PATH=evaluacion-pi/postgres

# Local backup folder. Keep it outside the repo on the server.
BACKUP_DIR=/var/backups/evaluacion-pi/postgres
BACKUP_PREFIX=evaluacion_pi
BACKUP_RETENTION_DAYS=30

# Optional binary overrides if pg_dump, pg_restore or rclone are not in PATH.
# PG_DUMP_BIN=/usr/bin/pg_dump
# PG_RESTORE_BIN=/usr/bin/pg_restore
# RCLONE_BIN=/usr/bin/rclone
